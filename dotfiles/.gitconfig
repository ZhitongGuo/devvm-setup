[user]
	email = paytonguo@meta.com
	name = Zhitong Guo
[credential "https://github.com"]
    helper =
    helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !/opt/homebrew/bin/gh auth git-credential
[core]
    editor = nvim
[init]
    defaultBranch = main
[pull]
    rebase = true
[diff]
    colorMoved = default
[merge]
    conflictstyle = diff3

# ─── Meta DevVM settings (uncomment on DevVM) ───
# [http "https://git.internal.tfbnw.net/"]
#     sslCert = /var/facebook/credentials/YOUR_USERNAME/x509/YOUR_USERNAME.pem
# [http "https://manifold.c2p.facebook.net/"]
#     sslCert = /var/facebook/credentials/YOUR_USERNAME/x509/YOUR_USERNAME.pem
# [http]
#     proxy = fwdproxy:8080
#     proxySSLCert = /var/facebook/credentials/YOUR_USERNAME/x509/YOUR_USERNAME.pem
#     proxySSLKey = /var/facebook/credentials/YOUR_USERNAME/x509/YOUR_USERNAME.pem
# [https]
#     proxy = fwdproxy:8080
